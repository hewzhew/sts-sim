    println!("\n閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀?);
    println!("棣冩惓 SimpleMap Conversion (for GameState)");
    println!("閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀?);
    
    let simple_map = SimpleMap::from_map(&maps[0]);
    println!("{}", simple_map);
    
    println!("\n棣冩惙 Starting positions: {:?}", simple_map.get_starting_positions());
    println!("   Total connected nodes: {}", simple_map.nodes.len());
    
    // Show a path through the map
    println!("\n棣冩瘽 Example path from start:");
    if let Some(&start_idx) = simple_map.get_starting_positions().first() {
        let mut current = start_idx;
        for floor in 0..15 {
            if let Some(node) = simple_map.get(current) {
                println!("   Floor {:2}: ({}, {}) - {}", floor, node.x, node.y, node.room_type);
                if let Some(&next) = node.children.first() {
                    current = next;
                } else {
                    break;
                }
            }
        }
    }
    
    // Integrate map into GameState
    println!("\n閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀?);
    println!("棣冨箖 GameState Integration");
    println!("閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀?);
    
    let mut state = GameState::new(game_seed as u64);
    state.map = Some(SimpleMap::from_map(&maps[0]));
    state.act = 1;
    state.floor = 0;
    
    // Simulate picking a starting node
    if let Some(ref map) = state.map {
        let starts = map.get_starting_positions();
        state.current_map_node = starts.first().copied();
        println!("\n   Act: {}", state.act);
        println!("   Floor: {}", state.floor);
        println!("   Current node: {:?}", state.current_map_node);
        
        if let Some(idx) = state.current_map_node {
            if let Some(node) = map.get(idx) {
                println!("   Room type: {}", node.room_type);
                println!("   Available paths: {:?}", node.children);
            }
        }
    }
    
    println!("\n閴?Phase 5.1 Demo Complete!");
    println!("\nKey achievements:");
    println!("  閴?Map generation algorithm from sts_map_oracle");
    println!("  閴?RoomType enum (M/E/R/$/?/T/B)");
    println!("  閴?MapRoomNode with edges and parents");
    println!("  閴?Room assignment rules (no Elite/Rest before floor 5, etc.)");
    println!("  閴?Fixed rooms (Floor 0=Monster, 8=Treasure, 14=Rest)");
    println!("  閴?SimpleMap for GameState integration");
    println!("  閴?ASCII visualization matching sts_map_oracle output");
    
    Ok(())
