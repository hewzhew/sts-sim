    let mut state = GameState::new(12345);
    
    // === Give player some relics ===
    println!("\n棣冨返 Adding Relics:");
    
    // Burning Blood (Ironclad starter) - heal 6 at end of combat
    state.relics.push(RelicInstance::new("BurningBlood"));
    println!("   棣冩暉 Burning Blood - Heal 6 HP at end of combat");
    
    // Vajra - gain 1 Strength at start of combat
    state.relics.push(RelicInstance::new("Vajra"));
    println!("   棣冩尛 Vajra - +1 Strength at start of combat");
    
    // Pen Nib - every 10th attack deals double damage
    state.relics.push(RelicInstance::new("PenNib"));
    println!("   棣冩瀳閿?Pen Nib - Every 10th attack deals double damage");
    
    // Anchor - gain 10 block at start of combat
    state.relics.push(RelicInstance::new("Anchor"));
    println!("   閳?Anchor - +10 Block at start of combat");
    
    // Spawn a Cultist using the monster library
    let cultist_def = monster_library.get("Cultist")?;
    println!("\n棣冾浂 Spawning: {}", cultist_def.name);
    println!("   HP Range: {}", cultist_def.hp.base);
    
    let cultist = MonsterState::new(cultist_def, &mut state.rng, false);
    println!("   Rolled HP: {}/{}", cultist.hp, cultist.max_hp);
    state.enemies.push(cultist);
    
    // Build starter deck
    for _ in 0..5 {
        state.obtain_card(CardInstance::new("Strike_Ironclad".to_string(), 1));
    }
    for _ in 0..4 {
        state.obtain_card(CardInstance::new("Defend_Ironclad".to_string(), 1));
    }
    state.obtain_card(CardInstance::new("Bash".to_string(), 2));
    state.shuffle_draw_pile();
    
    // === Step 3: Battle Start - Trigger relics ===
    println!("\n閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀?);
