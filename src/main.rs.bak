    println!("Cultist HP: {}/{}", state.enemies[0].hp, state.enemies[0].max_hp);
    println!("Cultist Strength: {}", state.enemies[0].strength());
    
    // Play Bash
    if let Some(bash_idx) = state.hand.iter().position(|c| c.definition_id == "Bash") {
        println!("\n  Playing Bash on Cultist...");
        if let Err(e) = engine::play_card_from_hand(&mut state, &card_library, bash_idx, Some(0)) {
            println!("    Error: {}", e);
        }
        println!("  Cultist HP after Bash: {}", state.enemies[0].hp);
        println!("  Cultist Vulnerable: {} stacks", state.enemies[0].get_status("Vulnerable"));
    }
    
    engine::on_turn_end(&mut state, &card_library, None);
    state.end_turn();
    
    // === Step 7: Enemy Turn 2 ===
    engine::execute_enemy_turn(&mut state, &monster_library);
    
    // === Step 8: Simulate combat end (for Burning Blood) ===
    println!("\n閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀?);
    println!("棣冨汲 SIMULATING COMBAT VICTORY");
    println!("閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀ｉ埞浣叉敚閳逛讲鏀?);
    
