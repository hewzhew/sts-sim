    state.start_turn();
    engine::on_turn_start(&mut state, &card_library, None);
    
    println!("\nPlayer HP: {}/{}", state.player.current_hp, state.player.max_hp);
    println!("Player Block: {}", state.player.block);
    println!("Player Strength: {}", state.player.strength());
    println!("Energy: {}/{}", state.player.energy, state.player.max_energy);
    println!("Hand size: {} cards", state.hand.len());
    
    // Play some Strikes to build Pen Nib counter
    println!("\n  Playing attacks to build Pen Nib counter...");
    for i in 0..3 {
        if let Some(strike_idx) = state.hand.iter().position(|c| c.definition_id == "Strike_Ironclad") {
            println!("  [Attack {}] Playing Strike...", i + 1);
            if let Err(e) = engine::play_card_from_hand(&mut state, &card_library, strike_idx, Some(0)) {
                println!("    Error: {}", e);
            }
        }
    }
    
    println!("\n  Cultist HP after attacks: {}", state.enemies[0].hp);
    println!("  Pen Nib counter: {}/10", state.relics.iter().find(|r| r.id == "PenNib").map(|r| r.counter).unwrap_or(0));
    
    engine::on_turn_end(&mut state, &card_library, None);
    state.end_turn();
    
    // === Step 5: Enemy Turn 1 ===
    engine::execute_enemy_turn(&mut state, &monster_library);
    
    // === Step 6: Turn 2 ===
