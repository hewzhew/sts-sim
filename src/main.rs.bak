//! Slay the Spire Simulator - Phase 5 Demo
//!
//! This demonstrates the complete combat loop with:
//! 1. Relic system (Burning Blood, Vajra, Pen Nib)
//! 2. Enemy AI and behavior
//! 3. Full player-enemy turn cycle
//! 4. Procedural map generation

use sts_sim::core::schema::CardInstance;
use sts_sim::core::state::GameState;
use sts_sim::monsters::enemy::MonsterState;
use sts_sim::core::loader::{CardLibrary, MonsterLibrary};
use sts_sim::items::relics::RelicInstance;
use sts_sim::dungeon_mod::map::{generate_map, generate_all_maps, SimpleMap, Map};
use sts_sim::engine;

fn main() -> Result<(), Box<dyn std::error::Error>> {
